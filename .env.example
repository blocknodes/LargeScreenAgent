# LLM 配置
LLM_API_KEY=sk-your-llm-api-key
LLM_API_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-pro
LLM_MAX_TOKENS=65536

# 采样参数（留空则用模型默认值）。随机性偏高时建议降低：
#   想要近似确定性输出 → LLM_TEMPERATURE=0（配合 LLM_SEED 固定随机种子）
LLM_TEMPERATURE=0
# LLM_TOP_P=
# LLM_SEED=42
# LLM_PRESENCE_PENALTY=
# LLM_FREQUENCY_PENALTY=

# thinking（推理链）开关：留空=不干预（用模型默认）；1/true=开，0/false=关。
# 开/关时通过 extra_body 下发 chat_template_kwargs.enable_thinking（vLLM/Qwen 等自建服务约定）。
# 官方 API（如 DeepSeek）不认此字段时请留空，避免报错。Web 端的"启用思考"开关会按请求覆盖此项。
# LLM_ENABLE_THINKING=

# Web 搜索接口
WEB_SEARCH_API_KEY=your-web-search-api-key
WEB_SEARCH_URL=https://your-web-search-endpoint/search

# 平台内部媒资库检索接口
DB_SEARCH2_URL=https://your-db-search-endpoint/search

# 天气接口（可选，仅当问题涉及天气时使用）
WEATHER_API_KEY=your-weather-api-key

# system prompt 文件路径（默认同目录 slime_prompt.txt，一般无需修改）
# SLIME_PROMPT_FILE=slime_prompt.txt

# 经验库文件路径（experience learning 自动注入 prompt 的规则库）
# 为空或不设则不注入经验；也可通过 run_benchmark.py --experience 参数指定
# SLIME_EXPERIENCE_FILE=experience/rules.jsonl

# 经验总结模型（llm_learn.py 用强模型总结经验时的独立凭证）
# 三者任一留空则回退到上面的 LLM_API_KEY / LLM_API_URL / LLM_MODEL；
# 想让"跑分"和"学习总结"用不同服务商/模型时才需要单独配。
# LEARN_API_KEY=sk-your-stronger-model-key
# LEARN_API_URL=https://api.deepseek.com
# LEARN_MODEL=deepseek-r1

# Web 应用（slime_app.py）第二个可对比模型（模型 B）
# 配了 SLIME_APP_MODEL_B 后，网页会出现"对比两个模型"开关，可对同一 query 并排跑。
# 模型 A 复用上面的 LLM_*；B 的 URL/KEY 留空则回退到 A 的。
# SLIME_APP_MODEL_B=baseline35
# SLIME_APP_MODEL_B_LABEL=35B 模型
# SLIME_APP_MODEL_B_URL=http://10.19.96.219:4053
# SLIME_APP_MODEL_B_KEY=sk-xxx
# SLIME_APP_MODEL_A_LABEL=4B 模型   # 可选，给模型 A 起个显示名（默认用 LLM_MODEL）

# 调试开关（也可用命令行 --debug / --verbose / --quiet）
# SLIME_DEBUG=1
# SLIME_VERBOSE=0
# SLIME_DEBUG_STDOUT=0

# 日志文件路径（默认 logs/slime_<时间戳>.log；命令行 --no-log 可关闭）
# SLIME_LOG_FILE=run.log
